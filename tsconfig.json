{
  "extends": "@muigui/code-style/tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "./dist",
    "rootDir": "./src"
  },
  "exclude": [
    "./dist/**/*",

    "./src/**/*.test.*js*",
    "./src/**/*.test.*ts*",

    "./test/**/*"
  ],
  "include": [
    "./src/**/*"
  ]
}
