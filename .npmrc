@muigui:registry=https://registry.npmjs.org/

; Authentication is intentionally NOT stored here.
;   - CI/CD publishes via npm Trusted Publishing (OIDC) — no token required.
;   - For the one-time local bootstrap publish, pass the token on the CLI:
;       npm publish "--//registry.npmjs.org/:_authToken=${NPM_TOKEN}"
; (A committed `_authToken=${VAR}` line expands to an empty token in CI and
;  breaks OIDC trusted publishing, so it is deliberately omitted.)

;always-auth=true

color=always
package-lock=true

audit=false
fund=false
